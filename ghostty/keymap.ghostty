keybind=clear
keybind = ctrl+shift+,=reload_config
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+f=start_search
keybind = super+r=clear_screen
keybind = super+t=new_tab
keybind = alt+[=previous_tab
keybind = alt+]=next_tab
keybind = super+u=new_split:up
keybind = super+e=new_split:down
keybind = super+n=new_split:left
keybind = super+i=new_split:right
keybind = super+shift+u=goto_split:up
keybind = super+shift+e=goto_split:down
keybind = super+shift+n=goto_split:left
keybind = super+shift+i=goto_split:right
keybind = super+k=close_surface
keybind = ctrl+i=csi:105;5u
